<service_bundle type='manifest' name='network/blocklistd:default'>

<service
	name='network/blocklistd'
	type='service'
	version='1'>

	<create_default_instance enabled='false' />

	<single_instance />

	<dependency name='fs-local'
		grouping='require_all'
		restart_on='none'
		type='service'>
		<service_fmri
			value='svc:/system/filesystem/local' />
	</dependency>

	<dependency name='net-loopback'
		grouping='require_all'
		restart_on='none'
		type='service'>
		<service_fmri value='svc:/network/loopback' />
	</dependency>

	<dependency name='net-physical'
		grouping='require_all'
		restart_on='none'
		type='service'>
		<service_fmri value='svc:/network/physical' />
	</dependency>

	<dependency
	    name='ipfilter'
	    grouping='require_all'
	    restart_on='restart'
	    type='service'>
		<service_fmri value='svc:/network/ipfilter' />
	</dependency>

	<dependency name='config_file'
		grouping='require_all'
		restart_on='restart'
		type='path'>
		<service_fmri
		    value='file://localhost/etc/blocklistd.conf' />
	</dependency>

	<exec_method
		type='method'
		name='stop'
		exec=':kill'
		timeout_seconds='60' >
	</exec_method>

	<exec_method
		type='method'
		name='start'
		exec='/lib/svc/method/blocklistd start'
		timeout_seconds='60' >
	</exec_method>

	<exec_method
		type='method'
		name='refresh'
		exec=':kill -HUP'
		timeout_seconds='60' >
	</exec_method>

        <property_group name='config' type='application'>
		<stability value='Unstable' />

                <propval name='control_program' type='astring' value='none' />
                <propval name='config_file' type='astring' value='none' />
                <propval name='db_file' type='astring' value='none' />
                <propval name='sockpaths_file' type='astring' value='none' />
                <propval name='rulename' type='astring' value='none' />
                <propval name='sockpaths' type='astring' value='none' />
                <propval name='timeout' type='count' value='0' />
                <propval name='value_authorization' type='astring'
                         value='solaris.smf.value.firewall.config' />
        </property_group>

	<stability value='Unstable' />

	<template>
		<common_name>
			<loctext xml:lang='C'>blocklistd</loctext>
		</common_name>
		<documentation>
			<manpage title='blocklistd' section='8'
				manpath='/usr/share/man' />
			<manpage title='blocklistd.conf' section='5'
				manpath='/usr/share/man' />
		</documentation>
	</template>
</service>

</service_bundle>
